# Shell-Variablen für die Bash-Skripte (create.sh / drop.sh / deploy.sh).
# Bootstrap (create/drop) verbindet als Superuser (postgres); Objekt-Deploy
# (deploy.sh) verbindet als Framework-Schema-Owner di2_dev_fw.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=di2_dev

APP_VERSION_MAJOR=1
APP_VERSION_MINOR=0
APP_VERSION_BUILD=0
